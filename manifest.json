{
  "manifest_version": 3,
  "name": "TabMind",
  "version": "3.0.0",
  "description": "An intelligent workspace manager for your browser tabs.",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "TabMind"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "icons": {
    "16": "public/assets/icon-16.png",
    "48": "public/assets/icon-48.png",
    "128": "public/assets/icon-128.png"
  }
}

